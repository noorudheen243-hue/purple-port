generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                       @id @default(uuid())
  email                     String                       @unique
  password_hash             String
  full_name                 String
  role                      String
  department                String
  avatar_url                String?
  status                    String                       @default("ACTIVE")
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
  linked_client_id          String?                      @unique
  advance_balance           Float                        @default(0.0)
  aiAlertLogs               AIAlertLog[]
  assetsUploaded            Asset[]
  attendance                AttendanceRecord[]
  campaignsDefaulted        Campaign[]                   @relation("CampaignDefaultAssignee")
  messagesSent              ChatMessage[]
  chatParticipations        ChatParticipant[]
  readReceipts              ChatReadReceipt[]
  clientsManaged            Client[]                     @relation("AccountManager")
  created_invoices          ClientInvoice[]              @relation("InvoiceCreator")
  comments                  Comment[]
  contentApprovals          ContentDeliverable[]         @relation("ContentApprover")
  contentCreated            ContentDeliverable[]         @relation("ContentCreator")
  googleLogs                GoogleAdsLog[]               @relation("GoogleLogUser")
  createdApps               LauncherApp[]                @relation("LauncherAppCreator")
  leaveAllocations          LeaveAllocation[]
  leaveApprovals            LeaveRequest[]               @relation("LeaveApprover")
  leaveRequests             LeaveRequest[]
  meetingsOrganized         Meeting[]                    @relation("MeetingOrganizer")
  momsCreated               MeetingMoM[]                 @relation("MoMCreator")
  meetingNotifications      MeetingNotification[]
  meetingParticipations     MeetingParticipant[]
  meetingPerformanceReviews MeetingPerformanceReview[]
  meetingPresentations      MeetingPresentation[]
  metaLogs                  MetaAdsLog[]                 @relation("MetaLogUser")
  metaTokens                MetaToken[]                  @relation("UserMetaTokens")
  notifications             Notification[]
  payrollSlips              PayrollSlip[]
  regularisationApprovals   RegularisationRequest[]      @relation("RegularisationApprover")
  regularisationRequests    RegularisationRequest[]
  resignationApprovals      ResignationRequest[]         @relation("ResignationApprover")
  resignations              ResignationRequest[]         @relation("ResignationEmployee")
  seoLogs                   SeoLog[]                     @relation("SeoLogUser")
  subordinates              StaffProfile[]               @relation("ReportingManager")
  staffProfile              StaffProfile?
  stickyNotesOwned          StickyNote[]                 @relation("NoteOwner")
  stickyNotePermissions     StickyNotePermission[]
  tasksReported             Task[]                       @relation("TaskReporter")
  tasksAssignedBy           Task[]                       @relation("TaskAssignedBy")
  tasksAssigned             Task[]                       @relation("TaskAssignee")
  timeLogs                  TimeLog[]
  linkedClient              Client?                      @relation("ClientPortalUser", fields: [linked_client_id], references: [id])
  launcherPreferences       UserLauncherPreference[]
  notificationPreferences   UserNotificationPreference[]
  webLogs                   WebDevProject[]              @relation("WebLogUser")
  clientsAssigned           Client[]                     @relation("ClientStaff")

  @@index([role])
  @@index([department])
}

model StaffProfile {
  id                       String                 @id @default(uuid())
  staff_number             String                 @unique
  designation              String
  department               String
  date_of_joining          DateTime
  productivity_score       Float                  @default(0.0)
  sla_breach_count         Int                    @default(0)
  personal_contact         String?
  official_contact         String?
  whatsapp_number          String?
  personal_email           String?
  official_email           String?
  address                  String?
  city                     String?
  state                    String?
  pincode                  String?
  date_of_birth            DateTime?
  marital_status           String?
  blood_group              String?
  current_address          String?
  permanent_address        String?
  work_shift               String?
  emergency_contact_name   String?
  emergency_contact_number String?
  previous_company         String?
  total_experience_years   Float?                 @default(0.0)
  salary_type              String?
  base_salary              Float?
  hra                      Float?
  allowances               Float?
  conveyance_allowance     Float?
  accommodation_allowance  Float?
  incentive_eligible       Boolean                @default(false)
  payroll_status           String                 @default("ACTIVE")
  bank_name                String?
  account_holder_name      String?
  account_number           String?
  ifsc_code                String?
  account_type             String?
  pan_number               String?
  aadhar_number            String?
  payment_method           String?
  upi_id                   String?
  upi_linked_mobile        String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  user_id                  String                 @unique
  reporting_manager_id     String?
  biometric_device_id      String?                @unique
  biometricCredentials     BiometricCredential[]
  reporting_manager        User?                  @relation("ReportingManager", fields: [reporting_manager_id], references: [id])
  user                     User                   @relation(fields: [user_id], references: [id])
  shift_assignments        StaffShiftAssignment[]
}

model BiometricCredential {
  id           String       @id @default(uuid())
  staff_number String
  finger_index Int          @default(0)
  template     String
  algorithm    String?      @default("ZK")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  staff        StaffProfile @relation(fields: [staff_number], references: [staff_number], onDelete: Cascade)

  @@unique([staff_number, finger_index])
}

model AttendanceRecord {
  id                 String    @id @default(uuid())
  date               DateTime
  status             String
  check_in           DateTime?
  check_out          DateTime?
  work_hours         Float?
  shift_snapshot     String?
  grace_time_applied Int?
  method             String    @default("WEB")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user_id            String
  criteria_mode      String?
  shift_id           String?
  user               User      @relation(fields: [user_id], references: [id])

  @@unique([user_id, date])
  @@index([status])
  @@index([date])
}

model LeaveRequest {
  id               String   @id @default(uuid())
  type             String
  start_date       DateTime
  end_date         DateTime
  reason           String
  status           String   @default("PENDING")
  rejection_reason String?
  is_half_day      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user_id          String
  approver_id      String?
  approver         User?    @relation("LeaveApprover", fields: [approver_id], references: [id])
  user             User     @relation(fields: [user_id], references: [id])
}

model RegularisationRequest {
  id            String   @id @default(uuid())
  date          DateTime
  type          String
  reason        String
  status        String   @default("PENDING")
  exceeds_limit Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user_id       String
  approver_id   String?
  approver      User?    @relation("RegularisationApprover", fields: [approver_id], references: [id])
  user          User     @relation(fields: [user_id], references: [id])
}

model LeaveAllocation {
  id           String   @id @default(uuid())
  year         Int
  casual_leave Float    @default(0.0)
  sick_leave   Float    @default(0.0)
  earned_leave Float    @default(0.0)
  unpaid_leave Float    @default(0.0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user_id      String
  user         User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, year])
}

model Holiday {
  id           String   @id @default(uuid())
  name         String
  date         DateTime @unique
  description  String?
  is_recurring Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Shift {
  id                 String                 @id @default(uuid())
  name               String
  start_time         String
  end_time           String
  default_grace_time Int                    @default(15)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  assignments        StaffShiftAssignment[]
}

model StaffShiftAssignment {
  id         String       @id @default(uuid())
  staff_id   String
  shift_id   String
  from_date  DateTime
  to_date    DateTime?
  is_active  Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  grace_time Int?
  shift      Shift        @relation(fields: [shift_id], references: [id])
  staff      StaffProfile @relation(fields: [staff_id], references: [id])
}

model PayrollRun {
  id           String        @id @default(uuid())
  month        Int
  year         Int
  status       String        @default("DRAFT")
  type         String        @default("MONTHLY")
  total_payout Float         @default(0.0)
  processed_at DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  slips        PayrollSlip[]

  @@unique([month, year])
}

model PayrollSlip {
  id                      String     @id @default(uuid())
  basic_salary            Float
  hra                     Float
  allowances              Float
  incentives              Float      @default(0.0)
  deductions              Float      @default(0.0)
  net_pay                 Float
  payment_date            DateTime?
  status                  String     @default("PENDING")
  payroll_type            String     @default("MONTHLY")
  createdAt               DateTime   @default(now())
  payroll_run_id          String
  conveyance_allowance    Float      @default(0.0)
  accommodation_allowance Float      @default(0.0)
  advance_salary          Float      @default(0.0)
  lop_days                Float      @default(0.0)
  lop_deduction           Float      @default(0.0)
  other_deductions        Float      @default(0.0)
  advance_incentives      Float      @default(0.0)
  total_working_days      Int        @default(0)
  user_id                 String
  user                    User       @relation(fields: [user_id], references: [id])
  run                     PayrollRun @relation(fields: [payroll_run_id], references: [id])
}

model Client {
  id                       String                  @id @default(uuid())
  client_code              String?                 @unique
  name                     String
  brand_colors             String?
  logo_url                 String?
  industry                 String?
  status                   String                  @default("LEAD")
  contact_person           String?
  contact_number           String?
  company_email            String?
  address                  String?
  operating_country        String?
  operating_state          String?
  operating_locations_json String?
  advance_balance          Float                   @default(0.0)
  service_engagement       String?
  social_links             String?
  competitor_info          String?
  customer_avatar          String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  account_manager_id       String?
  ad_accounts              AdAccount[]
  ai_assumptions           AiAssumption[]
  ai_thoughts              AiThought[]
  campaigns                Campaign[]
  account_manager          User?                   @relation("AccountManager", fields: [account_manager_id], references: [id])
  content_strategies       ClientContentStrategy[]
  contentDeliverables      ContentDeliverable[]
  deals                    Deal[]
  googleAdsLogs            GoogleAdsLog[]
  invoices                 Invoice[]
  leads                    Lead[]
  marketingAccounts        MarketingAccount[]
  marketingCampaigns       MarketingCampaign[]
  marketingCampaignsBeta   MarketingCampaignBeta[]
  marketingGroups          MarketingGroup[]
  metaAdsLogs              MetaAdsLog[]
  reports                  Report[]
  seoLogs                  SeoLog[]
  strategy_masters         StrategyDataMaster[]
  strategy_inputs          StrategyInput?
  strategy_market_inputs   StrategyMarketInput?
  strategy_outputs         StrategyOutput?
  strategy_versions        StrategyVersion[]
  directTasks              Task[]
  portalUser               User?                   @relation("ClientPortalUser")
  webDevProjects           WebDevProject[]
  assigned_staff           User[]                  @relation("ClientStaff")

  @@index([status])
  @@index([account_manager_id])
}

model ContentType {
  id          String                  @id @default(uuid())
  name        String                  @unique
  description String?
  is_custom   Boolean                 @default(false)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  strategies  ClientContentStrategy[]
  tasks       Task[]                  @relation("TaskContentType")
}

model ClientContentStrategy {
  id              String       @id @default(uuid())
  type            String?
  monthly_target  Int          @default(0)
  quantity        Int?         @default(0)
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  client_id       String
  content_type_id String?
  content_type    ContentType? @relation(fields: [content_type_id], references: [id])
  client          Client       @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@unique([client_id, content_type_id])
}

model Campaign {
  id                  String          @id @default(uuid())
  title               String
  start_date          DateTime
  end_date            DateTime
  status              String          @default("PLANNING")
  budget              Float?
  goals               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  client_id           String
  default_assignee_id String?
  default_assignee    User?           @relation("CampaignDefaultAssignee", fields: [default_assignee_id], references: [id])
  client              Client          @relation(fields: [client_id], references: [id])
  ledgers             Ledger[]
  spend_snapshots     SpendSnapshot[]
  tasks               Task[]
}

model Task {
  id                    String             @id @default(uuid())
  sequence_id           Int                @default(0)
  title                 String
  description           String?
  status                String             @default("PLANNED")
  priority              String             @default("MEDIUM")
  type                  String             @default("GRAPHIC")
  content_type          String?
  content_type_id       String?
  nature                String             @default("NEW")
  category              String             @default("CAMPAIGN")
  due_date              DateTime?
  start_date            DateTime?
  department            String             @default("CREATIVE")
  campaign_type         String?
  sla_target            DateTime?
  sla_status            String             @default("ON_TRACK")
  actual_start_date     DateTime?
  completed_date        DateTime?
  estimated_hours       Float?
  ai_estimated_minutes  Int?
  actual_time_minutes   Int                @default(0)
  completion_rating     Int?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  campaign_id           String?
  client_id             String?
  marketing_campaign_id String?
  parent_task_id        String?
  assignee_id           String?
  assigned_by_id        String?
  reporter_id           String
  assets                Asset[]
  comments              Comment[]
  reporter              User               @relation("TaskReporter", fields: [reporter_id], references: [id])
  assigned_by           User?              @relation("TaskAssignedBy", fields: [assigned_by_id], references: [id])
  assignee              User?              @relation("TaskAssignee", fields: [assignee_id], references: [id])
  parent_task           Task?              @relation("SubTasks", fields: [parent_task_id], references: [id])
  sub_tasks             Task[]             @relation("SubTasks")
  marketingCampaign     MarketingCampaign? @relation(fields: [marketing_campaign_id], references: [id])
  client                Client?            @relation(fields: [client_id], references: [id])
  campaign              Campaign?          @relation(fields: [campaign_id], references: [id])
  contentTypeObj        ContentType?       @relation("TaskContentType", fields: [content_type_id], references: [id])
  dependents            TaskDependency[]   @relation("TaskBlockedBy")
  dependencies          TaskDependency[]   @relation("TaskBlocking")
  timeLogs              TimeLog[]

  @@index([status])
  @@index([priority])
  @@index([assignee_id])
  @@index([reporter_id])
  @@index([client_id])
  @@index([campaign_id])
  @@index([due_date])
}

model TaskDependency {
  id               String   @id @default(uuid())
  blocking_task_id String
  blocked_task_id  String
  createdAt        DateTime @default(now())
  blocked_task     Task     @relation("TaskBlockedBy", fields: [blocked_task_id], references: [id], onDelete: Cascade)
  blocking_task    Task     @relation("TaskBlocking", fields: [blocking_task_id], references: [id], onDelete: Cascade)

  @@unique([blocking_task_id, blocked_task_id])
}

model Asset {
  id            String   @id @default(uuid())
  original_name String
  file_url      String
  file_type     String
  size_bytes    Int?
  version       Int      @default(1)
  is_approved   Boolean  @default(false)
  createdAt     DateTime @default(now())
  task_id       String
  uploader_id   String
  uploader      User     @relation(fields: [uploader_id], references: [id])
  task          Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
}

model Comment {
  id                  String    @id @default(uuid())
  content             String
  is_revision_request Boolean   @default(false)
  createdAt           DateTime  @default(now())
  task_id             String
  author_id           String
  parent_comment_id   String?
  parent_comment      Comment?  @relation("ThreadedComments", fields: [parent_comment_id], references: [id])
  replies             Comment[] @relation("ThreadedComments")
  author              User      @relation(fields: [author_id], references: [id])
  task                Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id])
}

model TimeLog {
  id               String    @id @default(uuid())
  start_time       DateTime
  end_time         DateTime?
  duration_minutes Int?
  createdAt        DateTime  @default(now())
  task_id          String
  user_id          String
  user             User      @relation(fields: [user_id], references: [id])
  task             Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([task_id])
  @@index([start_time])
}

model Notification {
  id        String   @id @default(uuid())
  type      String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user_id   String
  user      User     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([read])
}

model AccountHead {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  type        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ledgers     Ledger[]
}

model Ledger {
  id           String        @id @default(uuid())
  name         String
  entity_type  String?
  entity_id    String?
  description  String?
  status       String        @default("ACTIVE")
  balance      Float         @default(0.0)
  currency     String        @default("INR")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  head_id      String
  campaign_id  String?
  ledger_code  String?       @unique
  journalLines JournalLine[]
  campaign     Campaign?     @relation(fields: [campaign_id], references: [id])
  head         AccountHead   @relation(fields: [head_id], references: [id])

  @@unique([name, head_id])
  @@index([entity_type, entity_id])
}

model JournalEntry {
  id                 String        @id @default(uuid())
  date               DateTime      @default(now())
  description        String
  reference          String?
  amount             Float
  type               String
  nature             String        @default("GENERAL")
  transaction_number String?       @unique
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  created_by_id      String
  invoice            Invoice?
  lines              JournalLine[]

  @@index([date])
  @@index([type])
}

model JournalLine {
  id        String       @id @default(uuid())
  debit     Float        @default(0.0)
  credit    Float        @default(0.0)
  createdAt DateTime     @default(now())
  entry_id  String
  ledger_id String
  ledger    Ledger       @relation(fields: [ledger_id], references: [id])
  entry     JournalEntry @relation(fields: [entry_id], references: [id])

  @@index([ledger_id])
}

model Invoice {
  id               String        @id @default(uuid())
  invoice_number   String        @unique
  date             DateTime
  due_date         DateTime
  status           String        @default("DRAFT")
  subtotal         Float
  tax_rate         Float         @default(18.0)
  tax_amount       Float
  discount         Float         @default(0.0)
  total_amount     Float
  balance_due      Float
  notes            String?
  terms            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  client_id        String
  journal_entry_id String?       @unique
  journal_entry    JournalEntry? @relation(fields: [journal_entry_id], references: [id])
  client           Client        @relation(fields: [client_id], references: [id])
  items            InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(uuid())
  description String
  quantity    Float   @default(1.0)
  unit_price  Float
  amount      Float
  invoice_id  String
  invoice     Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
}

model AdAccount {
  id          String       @id @default(uuid())
  platform    String
  external_id String
  name        String
  status      String       @default("ACTIVE")
  currency    String       @default("INR")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  client_id   String
  client      Client       @relation(fields: [client_id], references: [id])
  campaigns   AdCampaign[]
}

model SpendSnapshot {
  id            String    @id @default(uuid())
  date          DateTime
  spend_micros  BigInt
  impressions   Int       @default(0)
  clicks        Int       @default(0)
  conversions   Int       @default(0)
  revenue       Float     @default(0.0)
  currency      String    @default("INR")
  createdAt     DateTime  @default(now())
  campaign_id   String?
  ad_account_id String?
  campaign      Campaign? @relation(fields: [campaign_id], references: [id])

  @@unique([date, campaign_id])
}

model Lead {
  id                String                 @id @default(uuid())
  client_id         String
  source            String                 @default("MANUAL")
  date              DateTime               @default(now())
  name              String?
  phone             String?
  email             String?
  location          String?
  campaign_name     String?
  campaignId        String?                @map("campaign_id_marketing")
  group_id          String?
  quality           String?                @default("MEDIUM")
  status            String                 @default("NEW")
  feedback          String?
  externalLeadId    String?                @unique @map("external_lead_id")
  formId            String?                @map("form_id")
  fieldData         String?                @map("field_data")
  metaCreatedAt     DateTime?              @map("meta_created_at")
  campaign_beta_id  String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  aiSuggestions     AiFollowupSuggestion[]
  aiScore           AiLeadScore?
  deal              Deal?
  campaignBeta      MarketingCampaignBeta? @relation(fields: [campaign_beta_id], references: [id])
  group             MarketingGroup?        @relation(fields: [group_id], references: [id])
  marketingCampaign MarketingCampaign?     @relation(fields: [campaignId], references: [id])
  client            Client                 @relation(fields: [client_id], references: [id], onDelete: Cascade)
  follow_ups        LeadFollowUp[]

  @@index([client_id])
  @@index([campaignId])
}

model LeadFollowUp {
  id               String   @id @default(uuid())
  lead_id          String
  follow_up_number Int
  status           String
  notes            String?
  date             DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  channel          String?  @default("Phone Call")
  lead             Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@index([lead_id])
}

model StickyNote {
  id           String                 @id @default(uuid())
  title        String?                @default("New Note")
  color        String                 @default("#feff9c")
  position_x   Float                  @default(50)
  position_y   Float                  @default(50)
  width        Float                  @default(250)
  height       Float                  @default(300)
  is_minimized Boolean                @default(false)
  is_visible   Boolean                @default(true)
  is_shared    Boolean                @default(false)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  user_id      String
  team_id      String?
  user         User                   @relation("NoteOwner", fields: [user_id], references: [id])
  permissions  StickyNotePermission[]
  tasks        StickyTask[]
}

model StickyTask {
  id           String     @id @default(uuid())
  content      String
  is_completed Boolean    @default(false)
  completed_at DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  note_id      String
  note         StickyNote @relation(fields: [note_id], references: [id], onDelete: Cascade)
}

model StickyNotePermission {
  id        String     @id @default(uuid())
  role      String
  createdAt DateTime   @default(now())
  note_id   String
  user_id   String
  user      User       @relation(fields: [user_id], references: [id])
  note      StickyNote @relation(fields: [note_id], references: [id], onDelete: Cascade)

  @@unique([note_id, user_id])
}

model MetaToken {
  id                String             @id @default(uuid())
  access_token      String
  refresh_token     String?
  expires_at        DateTime?
  scopes            String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user_id           String
  account_name      String?
  meta_user_id      String?
