  clientId          String   @unique
  positioning       String?
  channel_mix       String?
  funnel_model      String?
  kpi_targets       String?
  execution_plan    String?
  tactical_ads_json String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model StrategyVersion {
  id              String   @id @default(uuid())
  clientId        String
  version_name    String?
  input_snapshot  String
  output_snapshot String
  createdAt       DateTime @default(now())
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model AiAssumption {
  id              String   @id @default(uuid())
  clientId        String
  category        String
  assumption_text String
  source          String?
  createdAt       DateTime @default(now())
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model StrategyMarketInput {
  id                  String                   @id @default(uuid())
  clientId            String                   @unique
  industry_benchmarks String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  competitor          StrategyCompetitorData?
  demand              StrategyDemandData?
  client              Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  positioning         StrategyPositioningData?
}

model StrategyPositioningData {
  id            String              @id @default(uuid())
  marketInputId String              @unique
  data_json     String
  marketInput   StrategyMarketInput @relation(fields: [marketInputId], references: [id], onDelete: Cascade)
}

model StrategyCompetitorData {
  id            String              @id @default(uuid())
  marketInputId String              @unique
  data_json     String
  marketInput   StrategyMarketInput @relation(fields: [marketInputId], references: [id], onDelete: Cascade)
}

model StrategyDemandData {
  id            String              @id @default(uuid())
  marketInputId String              @unique
  data_json     String
  marketInput   StrategyMarketInput @relation(fields: [marketInputId], references: [id], onDelete: Cascade)
}

model AiThought {
  id        String     @id @default(uuid())
  clientId  String?
  type      String
  reasoning String
  createdAt DateTime   @default(now())
  actions   AiAction[]
  client    Client?    @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model AiAction {
  id          String    @id @default(uuid())
  thoughtId   String
  command     String
  params_json String
  status      String    @default("PROPOSED")
  executedAt  DateTime?
  thought     AiThought @relation(fields: [thoughtId], references: [id])

  @@index([thoughtId])
}

model StrategyDataMaster {
  id            String                @id @default(uuid())
  strategy_id   String?               @unique
  strategy_name String
  status        String                @default("Draft")
  client_id     String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  client        Client                @relation(fields: [client_id], references: [id], onDelete: Cascade)
  sections      StrategyDataSection[]
  logs          StrategyProgressLog[]

  @@index([client_id])
}

model StrategyDataSection {
  id           String             @id @default(uuid())
  master_id    String
  section_name String
  data_json    String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  master       StrategyDataMaster @relation(fields: [master_id], references: [id], onDelete: Cascade)

  @@unique([master_id, section_name])
}

model StrategyProgressLog {
  id            String             @id @default(uuid())
  master_id     String
  action        String
  data_snapshot String?
  createdAt     DateTime           @default(now())
  master        StrategyDataMaster @relation(fields: [master_id], references: [id], onDelete: Cascade)
}

model LedgerMaster {
  id           String                @id @default(uuid())
  entity_type  String
  entity_id    String?
  ledger_name  String
  ledger_type  String                @default("unified")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  metadata     String?
  mappings     LegacyLedgerMapping[]
  transactions UnifiedTransaction[]
}

model UnifiedTransaction {
  id               String       @id @default(uuid())
  ledger_id        String
  transaction_type String
  amount           Float
  date             DateTime     @default(now())
  description      String
  reference        String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  category         String?
  sub_type         String?
  ledger           LedgerMaster @relation(fields: [ledger_id], references: [id])
}

model LegacyLedgerMapping {
  id                    String       @id @default(uuid())
  new_ledger_id         String
  old_income_ledger_id  String?
  old_expense_ledger_id String?
  migration_date        DateTime     @default(now())
  createdAt             DateTime     @default(now())
  ledger                LedgerMaster @relation(fields: [new_ledger_id], references: [id])
}
