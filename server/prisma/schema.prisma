// --- MODULE: MEETING MANAGEMENT ---

model Meeting {
  id          String   @id @default(uuid())
  title       String
  type        String // WEEKLY, MONTHLY, CUSTOM
  date        DateTime
  time        String
  duration    Int // in minutes
  agenda      String? // Rich text or Plain text
  status      String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  attachments String? // JSON string or comma-separated URLs

  organizer_id String
  organizer    User   @relation("MeetingOrganizer", fields: [organizer_id], references: [id])

  participants  MeetingParticipant[]
  mom           MeetingMoM?
  presentations MeetingPresentation[]
  notifications MeetingNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MeetingParticipant {
  id         String @id @default(uuid())
  meeting_id String
  user_id    String
  status     String @default("INVITED") // INVITED, ATTENDED, ABSENT

  meeting Meeting @relation(fields: [meeting_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([meeting_id, user_id])
}

model MeetingMoM {
  id           String  @id @default(uuid())
  meeting_id   String  @unique
  summary      String?
  key_points   String?
  decisions    String?
  action_items String? // JSON or text
  status       String  @default("DRAFT") // DRAFT, SUBMITTED, REVIEWED, APPROVED
  remarks      String? // Admin feedback

  creator_id String
  creator    User   @relation("MoMCreator", fields: [creator_id], references: [id])

  meeting             Meeting                    @relation(fields: [meeting_id], references: [id], onDelete: Cascade)
  performance_reviews MeetingPerformanceReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MeetingPerformanceReview {
  id           String  @id @default(uuid())
  mom_id       String
  user_id      String
  rating       Int // 1 to 5
  strengths    String?
  improvements String?
  comments     String?

  mom  MeetingMoM @relation(fields: [mom_id], references: [id], onDelete: Cascade)
  user User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([mom_id, user_id])
}

model MeetingPresentation {
  id           String  @id @default(uuid())
  meeting_id   String
  presenter_id String
  topic        String
  description  String?
  feedback     String?

  meeting   Meeting @relation(fields: [meeting_id], references: [id], onDelete: Cascade)
  presenter User    @relation(fields: [presenter_id], references: [id], onDelete: Cascade)
}

model MeetingNotification {
  id         String  @id @default(uuid())
  meeting_id String
  user_id    String
  message    String
  is_read    Boolean @default(false)
  type       String // SCHEDULED, UPDATE, MOM_SUBMITTED, MOM_REVIEWED

  meeting Meeting @relation(fields: [meeting_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// --- MODULE: AI SMART NOTIFICATIONS ---

model AINotificationRule {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  trigger_type    String   // TASK_DELAY, ATTENDANCE_PATTERN, PENDING_REQUEST, PAYROLL, MEETING_FOLLOWUP, CLIENT_ALERT
  is_active       Boolean  @default(true)
  config_json     String?  // JSON containing threshold (days/hours), frequency, etc.
  message_template String
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model NotificationEvent {
  id              String   @id @default(uuid())
  event_name      String   @unique // ATTENDANCE_MARKED, TASK_ASSIGNED, etc
  description     String?
  default_template String
  
  createdAt       DateTime @default(now())
}

model NotificationLog {
  id              String   @id @default(uuid())
  user_id         String
  channel         String   // WHATSAPP, APP
  message         String
  status          String   // SENT, FAILED, PENDING
  error_message   String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UserNotificationPreference {
  id              String   @id @default(uuid())
  user_id         String
  category        String   // ATTENDANCE, TASKS, PAYROLL, REQUESTS, MEETINGS
  app_enabled     Boolean  @default(true)
  whatsapp_enabled Boolean @default(true)

  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([user_id, category])
}

model AIAlertLog {
  id              String   @id @default(uuid())
  user_id         String
  alert_type      String   // WARNING, CRITICAL, INSIGHT
  title           String
  message         String
  suggestion      String?
  is_resolved     Boolean  @default(false)
  escalation_level Int     @default(1)
  
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}


model AttendanceCriteriaConfig {
  id          String   @id @default(uuid())
  rule_type   String   // PRESENT, HALF_DAY, ABSENT
  rule_code   String   @unique // A1, C1, B1 etc.
  name        String
  description String?
  is_enabled  Boolean  @default(true)
  parameters  String   @default("{}") // JSON string for flexibility

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Deal {
  id                String   @id @default(uuid())
  title             String
  description       String?
  value             Float    @default(0.0)
  stage             String   @default("DISCOVERY") // DISCOVERY, QUALIFICATION, PROPOSAL, NEGOTIATION, CLOSING
  status            String   @default("OPEN") // OPEN, WON, LOST, STALLED
  expected_close_date DateTime?
  
  clientId          String
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  leadId            String?  @unique
  lead              Lead?    @relation(fields: [leadId], references: [id])

  // AI Data
  aiPrediction      AiDealPrediction?
  aiSuggestions     AiFollowupSuggestion[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([stage])
  @@index([status])
}

model AiLeadScore {
  id              String   @id @default(uuid())
  leadId          String   @unique
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  score           Int      @default(0) // 0-100
  label           String   @default("COLD") // HOT, WARM, COLD
  
  factors_json    String   @default("{}") // Reasons for the score
  last_calculated DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AiDealPrediction {
  id              String   @id @default(uuid())
  dealId          String   @unique
  deal            Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  
  probability     Float    @default(0.0) // 0.0 to 1.0
  risk_level      String   @default("LOW") // LOW, MEDIUM, HIGH
  
  factors_json    String   @default("{}")
  last_calculated DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AiFollowupSuggestion {
  id              String   @id @default(uuid())
  
  leadId          String?
  lead            Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  dealId          String?
  deal            Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  
  suggested_date  DateTime
  suggested_type  String   // CALL, EMAIL, MEETING
  reason          String
  status          String   @default("PENDING") // PENDING, COMPLETED, IGNORED

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AiSalesInsight {
  id              String   @id @default(uuid())
  type            String   // CONVERSION_RATE, SOURCE_EFFECTIVENESS, STAFF_PERFORMANCE
  data_json       String   @default("{}")
  period          String   // WEEKLY, MONTHLY
  
  createdAt       DateTime @default(now())
}

model AiForecast {
  id                String   @id @default(uuid())
  month             Int
  year              Int
  expected_revenue  Float
  pipeline_value    Float
  data_json         String   @default("{}")
  
  createdAt         DateTime @default(now())

  @@unique([month, year])
}
